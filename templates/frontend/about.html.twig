{% extends 'base.html.twig' %}

{% block title %}About | Tunisian Cuisine{% endblock %}

{% block body %}
<!-- Hero Section -->
<section class="hero">
    <div class="hero-overlay">
        <div class="hero-content">
            <h1>About Tunisian Cuisine</h1>
            <p class="hero-subtitle">
                Where ancient spices meet Mediterranean shores in a symphony of
                unforgettable flavors
            </p>
        </div>
    </div>
</section>

<!-- Introduction -->
<section class="intro-section">
    <div class="container">
        <p class="intro-text">
            Tunisian cuisine is a vibrant reflection of the country's rich history
            and diverse cultural influences. Situated at the crossroads of
            Mediterranean and North African civilizations, Tunisia has developed a
            unique culinary identity that combines the best of multiple worlds.
        </p>
    </div>
</section>

<!-- Feature Cards -->
<section class="features-section">
    <div class="container">
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fa-solid fa-globe"></i>
                </div>
                <h3 class="feature-title">Cultural Fusion</h3>
                <p class="feature-description">
                    A unique blend of Berber, Arab, Turkish, Italian, and French
                    culinary traditions
                </p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fa-solid fa-utensils"></i>
                </div>
                <h3 class="feature-title">Spice Mastery</h3>
                <p class="feature-description">
                    Famous for harissa and unique spice blends like tabil and ras el
                    hanout
                </p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fa-solid fa-tree"></i>
                </div>
                <h3 class="feature-title">Mediterranean Bounty</h3>
                <p class="feature-description">
                    Fresh seafood, olive oil, citrus fruits, and dates from Tunisia's
                    diverse landscape
                </p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fa-solid fa-heart"></i>
                </div>
                <h3 class="feature-title">Family Tradition</h3>
                <p class="feature-description">
                    Recipes passed down through generations, with food at the heart of
                    hospitality
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Historical & Signature Section -->
<section class="details-section">
    <div class="container">
        <div class="details-grid">
            <div class="detail-box">
                <div class="detail-header">
                    <div class="detail-line"></div>
                    <h2>Historical Influences</h2>
                </div>
                <div class="detail-content">
                    <div class="detail-item">
                        <h4>Berber Heritage:</h4>
                        <p>
                            The indigenous Berber people laid the foundation with
                            couscous, which remains the national dish of Tunisia.
                        </p>
                    </div>
                    <div class="detail-item">
                        <h4>Arab Conquest (7th century):</h4>
                        <p>
                            Brought new spices, cooking techniques, and dishes like
                            tajines and various grilled meats.
                        </p>
                    </div>
                    <div class="detail-item">
                        <h4>Ottoman Era (16th-19th century):</h4>
                        <p>
                            Introduced pastries, filled breads, and the art of preserving
                            vegetables.
                        </p>
                    </div>
                    <div class="detail-item">
                        <h4>French Era (1881-1956):</h4>
                        <p>
                            Added baguettes, café culture, and refined cooking techniques.
                        </p>
                    </div>
                </div>
            </div>
            <div class="detail-box">
                <div class="detail-header">
                    <div class="detail-line"></div>
                    <h2>Signature Elements</h2>
                </div>
                <div class="detail-content">
                    <div class="detail-item">
                        <h4>Harissa:</h4>
                        <p>
                            The iconic red chili paste that appears in nearly every meal,
                            made from hot peppers, garlic, and spices.
                        </p>
                    </div>
                    <div class="detail-item">
                        <h4>Tabil:</h4>
                        <p>
                            A distinctive spice blend of coriander, caraway, garlic, and
                            chili peppers unique to Tunisia.
                        </p>
                    </div>
                    <div class="detail-item">
                        <h4>Olive Oil:</h4>
                        <p>
                            Tunisia is one of the world's top olive oil producers, used
                            generously in cooking.
                        </p>
                    </div>
                    <div class="detail-item">
                        <h4>Seafood:</h4>
                        <p>
                            With over 1,300 km of coastline, fresh fish and seafood
                            feature prominently.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Food Culture Section -->
<section class="culture-section">
    <div class="container">
        <div class="culture-header">
            <i class="fa-solid fa-star"></i>
            <h2>Food & Hospitality Culture</h2>
        </div>
        <div class="culture-grid">
            <div class="culture-item">
                <h3>Communal Dining</h3>
                <p>
                    Meals are traditionally shared from large communal dishes,
                    symbolizing unity and family bonds. Couscous on Sundays is a
                    cherished weekly tradition.
                </p>
            </div>
            <div class="culture-item">
                <h3>Generous Hospitality</h3>
                <p>
                    Guests are treated like royalty. It's customary to offer mint tea,
                    dates, and elaborate meals to visitors, even unexpected ones.
                </p>
            </div>
            <div class="culture-item">
                <h3>Seasonal Celebrations</h3>
                <p>
                    Special dishes mark holidays and life events. Ramadan features
                    unique soups and sweets, while weddings showcase elaborate
                    multi-course feasts.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Did You Know Section -->
<section class="facts-section">
    <div class="container">
        <div class="facts-header">
            <i class="fa-solid fa-lightbulb"></i>
            <h2>Did You Know?</h2>
        </div>
        <div class="facts-grid">
            <div class="fact-item">
                <i class="fa-solid fa-circle"></i>
                <p>
                    Tunisia exports more dates than any other country in North Africa,
                    with over 250 varieties
                </p>
            </div>
            <div class="fact-item">
                <i class="fa-solid fa-circle"></i>
                <p>
                    The word "couscous" comes from the Berber word "seksu" meaning
                    "well-rolled"
                </p>
            </div>
            <div class="fact-item">
                <i class="fa-solid fa-circle"></i>
                <p>
                    Brik, the famous fried pastry, is said to have originated from
                    Turkish börek during Ottoman rule
                </p>
            </div>
            <div class="fact-item">
                <i class="fa-solid fa-circle"></i>
                <p>
                    Tunisian harissa was granted EU Protected Geographical Indication
                    status in 2018
                </p>
            </div>
            <div class="fact-item">
                <i class="fa-solid fa-circle"></i>
                <p>
                    Mint tea is the traditional welcome drink, often sweetened and
                    served multiple times
                </p>
            </div>
            <div class="fact-item">
                <i class="fa-solid fa-circle"></i>
                <p>
                    Tunisia has practiced tuna fishing since Phoenician times,
                    especially in the north (like Bizerte). That’s why tuna appears
                    everywhere—from sandwiches to salads to pasta—far more than in
                    most Arab cuisines.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- About Our Website Section -->
<section class="mission-section">
    <div class="container">
        <div class="mission-content">
            <div class="mission-icon">
                <i class="fa-solid fa-compass"></i>
            </div>
            <h2 class="mission-title">Our Mission</h2>
            <p class="mission-subtitle">
                Bringing Tunisia's Culinary Heritage to Your Kitchen
            </p>
            <p class="mission-description">
                We are passionate food enthusiasts and cultural ambassadors
                dedicated to preserving and sharing the authentic flavors of
                Tunisia. Our website serves as a digital cookbook and cultural
                guide, bridging the gap between traditional Tunisian kitchens and
                modern home cooks worldwide. Whether you're discovering Tunisian
                cuisine for the first time or reconnecting with cherished family
                recipes, we're here to guide your culinary journey with authentic
                recipes, cooking techniques, and the stories behind every dish.
            </p>
            <div class="mission-features">
                <div class="mission-feature">
                    <i class="fa-solid fa-book"></i>
                    <h4>Authentic Recipes</h4>
                    <p>Traditional dishes passed down through generations</p>
                </div>
                <div class="mission-feature">
                    <i class="fa-solid fa-users"></i>
                    <h4>Community Driven</h4>
                    <p>Share your stories and family recipes with us</p>
                </div>
                <div class="mission-feature">
                    <i class="fa-solid fa-graduation-cap"></i>
                    <h4>Learn & Grow</h4>
                    <p>Master techniques from basic to advanced</p>
                </div>
                <div class="mission-feature">
                    <i class="fa-solid fa-globe-africa"></i>
                    <h4>Cultural Heritage</h4>
                    <p>Discover the history behind every flavor</p>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
