{% extends 'base.html.twig' %}

{% block title %}Tunisian Recipes{% endblock %}

{% block body %}
<section class="hero" style="background-image: url('https://images.unsplash.com/photo-1542838132-92c53300491e?w=1400&q=80');">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
        <div class="hero-icon">
            <i class="fa-solid fa-utensils" style="color: #fff;"></i>
        </div>
        <h1>Tunisian Recipes</h1>
        <p>Discover authentic dishes from every region of Tunisia</p>
    </div>
</section>

<section class="intro text-center">
    <div class="container">
        <p>From the bustling markets of Tunis to the coastal kitchens of Sfax, explore the recipes that define Tunisian culinary heritage.</p>
    </div>
</section>

<section class="filters container">
    <form method="get" action="{{ path('app_recipes') }}" class="recipe-search-form">
        <div class="search-bar-wrapper" style="margin-bottom: 16px;">
            <div class="search-bar" style="max-width: 520px;">
                <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" name="q" value="{{ query }}" placeholder="Search recipes by name, ingredient, or region..." />
            </div>
            <button type="submit" class="nav-btn" style="border: none; cursor: pointer;">
                <i class="fa-solid fa-search"></i> Search
            </button>
        </div>
        <div class="categories" style="justify-content: center;">
            <span class="cat-label">Filter by Region</span>
            <a href="{{ path('app_recipes') }}" class="cat-btn {{ selectedRegion == 0 ? 'active' : '' }}">All</a>
            {% for region in regions %}
                <a href="{{ path('app_recipes', {region: region.id}) }}" class="cat-btn {{ selectedRegion == region.id ? 'active' : '' }}">{{ region.name }}</a>
            {% endfor %}
        </div>
    </form>
</section>

<section class="regions-grid container">
    {% for recipe in recipes %}
        <a href="{{ path('app_recipe_show', {id: recipe.id}) }}" class="region-card recipe-card" style="text-decoration: none; color: inherit;">
            <div class="card-header">
                <h2>{{ recipe.name }}</h2>
                {% if recipe.region %}
                    <i class="fa-solid fa-location-dot" style="color: var(--primary-red);"></i>
                {% endif %}
            </div>
            {% if recipe.region %}
                <p class="card-subtitle">{{ recipe.region.name }} — {{ recipe.region.subtitle ?? '' }}</p>
            {% endif %}
            <p class="card-desc">{{ recipe.description }}</p>
            <div class="signature-dishes">
                <h4><span>|</span> Details</h4>
                <div class="tags">
                    <span class="tag"><i class="fa-regular fa-clock"></i> {{ recipe.prepTime + recipe.cookTime }} min</span>
                    <span class="tag"><i class="fa-solid fa-fire"></i> {{ recipe.difficulty }}</span>
                    <span class="tag"><i class="fa-solid fa-user-group"></i> {{ recipe.servings }} people</span>
                </div>
            </div>
        </a>
    {% else %}
        <div class="empty-state" style="grid-column: 1 / -1; text-align: center; padding: 60px;">
            <i class="fa-solid fa-basket-shopping" style="font-size: 3rem; color: var(--border); margin-bottom: 16px; display: block;"></i>
            <p style="font-family: var(--font-display); font-size: 1.3rem; color: var(--text-muted); font-style: italic;">No recipes found matching your search.</p>
        </div>
    {% endfor %}
</section>
{% endblock %}
