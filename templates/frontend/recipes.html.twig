{% extends 'base.html.twig' %}

{% block title %}Tunisian Cuisine — Recipes{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/recipes.css') }}">
{% endblock %}

{% block body %}
<div class="recipes-page"
     id="favorites"
     data-user-logged-in="{{ app.user ? '1' : '0' }}"
     data-favorite-ids="{{ favoriteRecipeIds|json_encode|e('html_attr') }}">
    <header class="recipes-hero">
        <div class="recipes-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1746274394124-141a1d1c5af3?w=1080&q=80');"></div>
        <div class="recipes-hero-overlay"></div>
        <div class="recipes-hero-pattern" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <pattern id="tile-pattern" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
                        <circle cx="40" cy="40" r="20" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.15"/>
                        <circle cx="40" cy="40" r="10" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.2"/>
                        <path d="M 40 20 L 40 60 M 20 40 L 60 40" stroke="currentColor" stroke-width="0.5" opacity="0.15"/>
                    </pattern>
                </defs>
                <rect width="100%" height="100%" fill="url(#tile-pattern)"/>
            </svg>
        </div>
        <div class="recipes-hero-content">
            <div class="hero-icon"><i class="fa-solid fa-utensils"></i></div>
            <h1>Tunisian Cuisine</h1>
            <p class="hero-tagline">Discover authentic recipes from every corner of Tunisia — from the bustling streets of Tunis to the coastal beauty of Djerba</p>
            <form class="recipes-search-form" method="get" action="{{ path('app_home') }}">
                {% if selectedRegion > 0 %}
                    <input type="hidden" name="region" value="{{ selectedRegion }}">
                {% endif %}
                <div class="recipes-search-wrap">
                    <i class="fa-solid fa-magnifying-glass search-icon"></i>
                    <input
                        type="search"
                        name="q"
                        class="recipes-search-input"
                        value="{{ query }}"
                        placeholder="Search recipes, ingredients..."
                        autocomplete="off"
                    />
                </div>
            </form>
        </div>
    </header>

    <div class="recipes-region-bar">
        <div class="container">
            <nav class="recipes-region-tabs" aria-label="Filter by region">
                <a href="{{ path('app_home', query ? {q: query} : {}) }}" class="recipes-region-tab {{ selectedRegion == 0 ? 'active' : '' }}">All</a>
                {% for region in regions %}
                    <a href="{{ path('app_home', query ? {region: region.id, q: query} : {region: region.id}) }}"
                       class="recipes-region-tab {{ selectedRegion == region.id ? 'active' : '' }}">
                        {{ region.name }}
                    </a>
                {% endfor %}
            </nav>
        </div>
    </div>

    <main class="recipes-main">
        <div class="container">
            <section id="recipes-favorites-section" class="recipes-favorites" hidden>
                <h3><i class="fa-solid fa-heart"></i> Your Favorites <span class="recipes-count-badge" id="favorites-count">0</span></h3>
                <div class="recipes-grid" id="favorites-grid"></div>
            </section>

            <div class="recipes-results-header">
                <i class="fa-solid fa-location-dot"></i>
                <h2>
                    {% if selectedRegion > 0 %}
                        {% for region in regions %}
                            {% if region.id == selectedRegion %}Recipes from {{ region.name }}{% endif %}
                        {% endfor %}
                    {% else %}
                        All Recipes
                    {% endif %}
                </h2>
                <span class="recipes-count-badge">{{ recipes|length }}</span>
            </div>

            {% if recipes|length > 0 %}
                <div class="recipes-grid">
                    {% for recipe in recipes %}
                        {% set rating = recipeRatings[recipe.id] ?? null %}
                        <article class="recipe-card-wrap" data-recipe-id="{{ recipe.id }}">
                            <button type="button" class="recipe-fav-btn" data-recipe-id="{{ recipe.id }}" aria-label="Add to favorites">
                                <i class="fa-regular fa-heart"></i>
                            </button>
                            <a href="{{ path('app_recipe_show', {id: recipe.id}) }}" class="recipe-card">
                                <div class="recipe-card-image">
                                    {% set imgSrc = recipe_image(recipe) %}
                                    <img src="{{ imgSrc starts with 'http' ? imgSrc : asset(imgSrc) }}" alt="{{ recipe.name }}" loading="lazy">
                                    {% if recipe.difficulty %}
                                        <span class="recipe-difficulty {{ recipe.difficulty|lower }}">{{ recipe.difficulty }}</span>
                                    {% endif %}
                                    {% if rating and rating.count > 0 %}
                                        <span class="recipe-card-rating" aria-label="Rated {{ rating.average }} out of 5 from {{ rating.count }} reviews">
                                            <span class="recipe-card-rating__stars" aria-hidden="true">
                                                {% for i in 1..5 %}
                                                    <i class="fa-{{ i <= rating.average|round ? 'solid' : 'regular' }} fa-star"></i>
                                                {% endfor %}
                                            </span>
                                            <span class="recipe-card-rating__score">{{ rating.average }}</span>
                                            <span class="recipe-card-rating__count">({{ rating.count }})</span>
                                        </span>
                                    {% endif %}
                                </div>
                                <div class="recipe-card-body">
                                    <h3>{{ recipe.name }}</h3>
                                    <div class="recipe-card-badges">
                                        {% if recipe.region %}
                                            <span class="recipe-badge">{{ recipe.region.name }}</span>
                                        {% endif %}
                                        <span class="recipe-badge accent">{{ recipe.difficulty ?? 'Recipe' }}</span>
                                    </div>
                                    <p class="recipe-card-desc">{{ recipe.description }}</p>
                                </div>
                                <div class="recipe-card-footer">
                                    <span><i class="fa-regular fa-clock"></i> {{ recipe.prepTime ?? 0 }}m prep</span>
                                    <span><i class="fa-solid fa-fire-burner"></i> {{ recipe.cookTime ?? 0 }}m cook</span>
                                    <span><i class="fa-solid fa-user-group"></i> {{ recipe.servings ?? '—' }}</span>
                                </div>
                            </a>
                        </article>
                    {% endfor %}
                </div>
            {% else %}
                <div class="recipes-empty">
                    <i class="fa-solid fa-utensils"></i>
                    <h3>No recipes found</h3>
                    <p>Try adjusting your search or region filter.</p>
                    <a href="{{ path('app_home') }}" class="recipes-region-tab active" style="display:inline-flex;margin-top:1rem;">View all recipes</a>
                </div>
            {% endif %}
        </div>
    </main>
</div>
{% endblock %}
