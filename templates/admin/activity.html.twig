{% extends 'base.html.twig' %}

{% block title %}Activity log | Admin{% endblock %}

{% block body %}
<div class="tc-page" data-turbo="false">
    <header class="tc-page-header">
        <h1>Admin activity log</h1>
        <p><a href="{{ path('admin_dashboard') }}" style="color:var(--primary-red);">← Back to dashboard</a></p>
    </header>

    <div class="admin-wrap">
        <div class="tc-card activity-table-wrap">
            <table class="activity-table">
                <thead>
                    <tr>
                        <th>When</th>
                        <th>Admin</th>
                        <th>Action</th>
                        <th>Details</th>
                    </tr>
                </thead>
                <tbody>
                    {% for log in logs %}
                        <tr>
                            <td>{{ log.createdAt|date('Y-m-d H:i') }}</td>
                            <td>{{ log.admin.displayName }}</td>
                            <td><code>{{ log.action }}</code></td>
                            <td>{{ log.details }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="4">No activity yet.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
