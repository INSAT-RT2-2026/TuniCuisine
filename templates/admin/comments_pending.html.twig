{% extends 'base.html.twig' %}

{% block title %}Pending comments | Admin{% endblock %}

{% block body %}
<div class="tc-page" data-turbo="false">
    <header class="tc-page-header">
        <h1>Pending comments</h1>
        <p><a href="{{ path('admin_dashboard') }}" style="color:var(--primary-red);">← Back to dashboard</a></p>
    </header>

    <div class="admin-wrap">
        {% for comment in comments %}
            <article class="pending-card">
                <p style="margin:0 0 0.5rem;">
                    <strong>{{ comment.author.displayName }}</strong>
                    on <a href="{{ path('app_recipe_show', {id: comment.recipe.id}) }}" data-turbo="false">{{ comment.recipe.name }}</a>
                </p>
                <p style="margin:0;line-height:1.6;">{{ comment.content }}</p>
                <div class="pending-actions">
                    <form method="post" action="{{ path('admin_comment_approve', {id: comment.id}) }}">
                        <button type="submit" class="btn-primary-tc">Approve</button>
                    </form>
                    <form method="post" action="{{ path('admin_comment_reject', {id: comment.id}) }}">
                        <button type="submit" class="btn-secondary-tc">Reject</button>
                    </form>
                </div>
            </article>
        {% else %}
            <div class="tc-card"><p style="margin:0;">No pending comments.</p></div>
        {% endfor %}
    </div>
</div>
{% endblock %}
